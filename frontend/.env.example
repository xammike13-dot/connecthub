# Frontend Configuration
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000
# Production values should be set in Vercel project settings.
# Example: VITE_API_URL=https://your-backend.onrender.com/api
# Example: VITE_SOCKET_URL=https://your-backend.onrender.com

# Google Maps API (for maps integration)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# M-Pesa Daraja API (if needed on frontend)
VITE_MPESA_CONSUMER_KEY=your_mpesa_consumer_key

# Cloudinary (for image uploads)
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset