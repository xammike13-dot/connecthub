# Frontend Configuration
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000
# In production, set these to the Render backend URL and Vercel frontend origin.
# Example: VITE_API_URL=https://your-backend.onrender.com/api
# Example: VITE_SOCKET_URL=https://your-backend.onrender.com

# Google Maps API (for maps integration)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Cloudinary (for image uploads) - Using backend-signed uploads
# Cloudinary cloud name from backend .env
VITE_CLOUDINARY_CLOUD_NAME=dacj1krzs
