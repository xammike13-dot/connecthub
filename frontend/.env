# Frontend Configuration
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000
# Ensure frontend dev server port matches backend CORS origin settings
# If Vite is running on a different port, update backend FRONTEND_URL or this file accordingly

# Google Maps API (for maps integration)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Cloudinary (for image uploads) - Using backend-signed uploads
# Cloudinary cloud name from backend .env
VITE_CLOUDINARY_CLOUD_NAME=dacj1krzs
